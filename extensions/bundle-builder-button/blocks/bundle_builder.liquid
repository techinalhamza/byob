  "target": "section",
  "settings": [
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color",
      "default": "#008060"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#202223"
    },
    {
      "type": "text",
      "id": "small_basket_name",
      "label": "Small Basket Name",
      "default": "Small Basket"
    },
    {
      "type": "number",
      "id": "small_basket_min",
      "label": "Small Basket Min Products",
      "default": 1
    },
    {
      "type": "number",
      "id": "small_basket_max",
      "label": "Small Basket Max Products",
      "default": 3
    },
    {
      "type": "text",
      "id": "small_basket_price",
      "label": "Small Basket Price",
      "default": "29.99"
    },
    {
      "type": "text",
      "id": "large_basket_name",
      "label": "Large Basket Name",
      "default": "Large Basket"
    },
    {
      "type": "number",
      "id": "large_basket_min",
      "label": "Large Basket Min Products",
      "default": 4
    },
    {
      "type": "number",
      "id": "large_basket_max",
      "label": "Large Basket Max Products",
      "default": 6
    },
    {
      "type": "text",
      "id": "large_basket_price",
      "label": "Large Basket Price",
      "default": "49.99"
    },
    {
      "type": "text",
      "id": "extra_large_basket_name",
      "label": "Extra Large Basket Name",
      "default": "Extra Large Basket"
    },
    {
      "type": "number",
      "id": "extra_large_basket_min",
      "label": "Extra Large Basket Min Products",
      "default": 7
    },
    {
      "type": "number",
      "id": "extra_large_basket_max",
      "label": "Extra Large Basket Max Products",
      "default": 10
    },
    {
      "type": "text",
      "id": "extra_large_basket_price",
      "label": "Extra Large Basket Price",
      "default": "79.99"
    }
  ]
